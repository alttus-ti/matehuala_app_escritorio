    font: 700 10pt &quot;Arial&quot;;
}

QLineEdit {
    background-color: #FFFFFF;
    border: 2px solid #B8D8F3;
    border-radius: 12px;
    padding: 8px 10px;
    color: #2E3A46;
}

QLineEdit:focus {
    border: 2px solid #F3C623;
}

QCheckBox {
    color: #5E6A77;
    font: 9pt &quot;Arial&quot;;
}

QPushButton#pushButtonForgot {
    color: #E2A61C;
    font: 700 9pt &quot;Arial&quot;;
    border: none;
}

QPushButton#pushButtonForgot:hover {
    color: #C98900;
}

QPushButton#pushButtonLogin {
    background-color: #F3C623;
    color: #3D3D3D;
    border: none;
    border-radius: 12px;
    font: 700 10pt &quot;Arial&quot;;
    padding: 8px 16px;
}

QPushButton#pushButtonLogin:hover {
    background-color: #E4B61A;
}

QPushButton#pushButtonCancel {
    background-color: #7FB6E6;
    color: #FFFFFF;
    border: none;
    border-radius: 12px;
    font: 700 10pt &quot;Arial&quot;;
    padding: 8px 16px;
}

QPushButton#pushButtonCancel:hover {
    background-color: #6AA6DA;
}</string>
