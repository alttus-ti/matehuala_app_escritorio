    <string notr="true">QWidget#centralwidget {
    background-color: #EEF3F7;
}

QFrame#frameHeader {
    background-color: #D9ECFA;
    border: 2px solid #7FB6E6;
    border-radius: 18px;
}

QLabel#labelBrand {
    color: #F3B21A;
    font: 700 28pt &quot;Arial&quot;;
    letter-spacing: 2px;
}

QLabel#labelCompany {
    color: #5E98CC;
    font: 700 11pt &quot;Arial&quot;;
}

QLabel#labelWelcome {
